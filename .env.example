# Spotify (https://developer.spotify.com/dashboard)
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
# Set this to your Railway domain + /auth/spotify/callback (also add to Spotify dashboard)
SPOTIFY_REDIRECT_URI=https://YOUR-APP.up.railway.app/auth/spotify/callback

# SoundCloud (optional)
SOUNDCLOUD_USERNAME=your_soundcloud_username

# Event APIs (optional)
BANDSINTOWN_APP_ID=
SONGKICK_API_KEY=

# Supabase (https://supabase.com/dashboard → project settings → API)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# App (generate APP_SECRET_KEY with: python -c "import secrets; print(secrets.token_hex(32))")
APP_SECRET_KEY=generate-a-random-secret-here
# Set this to your Railway domain — no trailing slash
APP_HOST=https://YOUR-APP.up.railway.app
